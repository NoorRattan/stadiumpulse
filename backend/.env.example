ENVIRONMENT=development
SUPABASE_URL=https://replace-with-project-ref.supabase.co
SUPABASE_DB_URL=postgresql://postgres:replace-with-password@db.replace-with-project-ref.supabase.co:5432/postgres
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_JWKS_URL=
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated
ALLOWED_ORIGINS=http://localhost:5173
GROQ_API_KEY=replace-with-groq-api-key
GROQ_MODEL_PRIMARY=llama-3.1-8b-instant
GROQ_MODEL_LITE=llama-3.1-8b-instant
LOG_LEVEL=DEBUG
# Demo-only synthetic signal. Never label these values as physical sensor data.
SIMULATE_CROWD_DATA=false
CROWD_SIMULATION_INTERVAL_SECONDS=20
